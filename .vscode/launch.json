{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Launch dev-opt",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/dev-opt/rust.exe",
            "args": ["-m", "2"],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "rust: cargo build dev-opt"
        },
        {
            "name": "(Windows) Launch dev-opt bench",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/dev-opt/rust.exe",
            "args": ["-b", "-m", "2"],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "rust: cargo build dev-opt"
        },
        {
            "name": "(Windows) Launch dev-opt singlethread",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/dev-opt/rust.exe",
            "args": ["-s", "-m", "2"],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "rust: cargo build dev-opt"
        },
        {
            "name": "(Windows) Launch dev singlethread",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/target/debug/rust.exe",
            "args": ["-s", "-m", "2"],
            "stopAtEntry": false,
            "cwd": "${workspaceRoot}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "rust: cargo build dev"
        }
    ]
}